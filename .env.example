# ClariDoc - Firebase Configuration
# Rename this file to .env and fill in your Firebase project values

# Proyecto GRUPO (app-medica-3d3be) - Auth + Firestore
VITE_FIREBASE_GROUP_API_KEY=your-api-key-here
VITE_FIREBASE_GROUP_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_GROUP_PROJECT_ID=your-project-id
VITE_FIREBASE_GROUP_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_GROUP_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_GROUP_APP_ID=your-app-id
VITE_FIREBASE_GROUP_MEASUREMENT_ID=your-measurement-id

# Proyecto PRIVADO (claridoc-backend-kevin) - Storage
VITE_FIREBASE_PRIVATE_API_KEY=your-api-key-here
VITE_FIREBASE_PRIVATE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PRIVATE_PROJECT_ID=your-project-id
VITE_FIREBASE_PRIVATE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_PRIVATE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_PRIVATE_APP_ID=your-app-id
VITE_FIREBASE_PRIVATE_MEASUREMENT_ID=your-measurement-id
